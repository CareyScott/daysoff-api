# Postgres connection string (pooled URL in production; Neon injects DATABASE_URL)
DATABASE_URL=postgres://postgres:postgres@localhost:5433/bv_vacation

# Secret for signing JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=change-me

# Initial admin, created automatically when the users table is empty
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-too

# Extra comma-separated CORS origins (the deployed web app URL)
ALLOWED_ORIGINS=
